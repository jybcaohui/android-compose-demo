<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude DataStore preferences (contains token) from cloud backup -->
        <exclude domain="file" path="datastore/app_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude DataStore preferences (contains token) from device transfer -->
        <exclude domain="file" path="datastore/app_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
